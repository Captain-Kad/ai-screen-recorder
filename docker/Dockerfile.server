FROM node:20

# Install ffmpeg
RUN apt-get update && apt-get install -y ffmpeg

# Set working directory
WORKDIR /app

# Copy package files and install dependencies
COPY server/package*.json ./
RUN npm install

# Copy the rest of the server code
COPY server/ .

# Expose the backend port
EXPOSE 3001

# Start the server
CMD ["node", "index.js"]